# ─── Django Core ─────────────────────────────────────────────────────────────
DEBUG=True
SECRET_KEY=change-me-to-a-50-char-random-string-in-production
ALLOWED_HOSTS=localhost,127.0.0.1

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://refuconnect:refuconnect@db:5432/refuconnect

# ─── Redis / Celery ──────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ─── Google Cloud Translation ────────────────────────────────────────────────
GOOGLE_TRANSLATE_API_KEY=your-google-translate-api-key-here
GOOGLE_APPLICATION_CREDENTIALS=/app/credentials/gcp-service-account.json

# ─── Africa's Talking (SMS / USSD) ───────────────────────────────────────────
AFRICAS_TALKING_API_KEY=your-africas-talking-api-key-here
AFRICAS_TALKING_USERNAME=sandbox
SMS_SHORT_CODE=20880
USSD_SHORT_CODE=*284#

# ─── Meta WhatsApp Business API ──────────────────────────────────────────────
WHATSAPP_ACCESS_TOKEN=your-whatsapp-access-token-here
WHATSAPP_PHONE_NUMBER_ID=your-whatsapp-phone-number-id-here
WHATSAPP_VERIFY_TOKEN=your-custom-secret-string-you-choose
# App Secret — found in Meta App Dashboard → App Settings → Basic → "App secret"
WHATSAPP_APP_SECRET=your-meta-app-secret-here

# ─── Phone anonymisation ──────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
PHONE_HASH_SALT=your-random-64-char-hex-string-here

# ─── Encryption (AES-256-GCM) ────────────────────────────────────────────────
# Generate with: python -c "import os,base64; print(base64.urlsafe_b64encode(os.urandom(32)).decode())"
ENCRYPTION_KEY=your-32-byte-base64url-encoded-key-here

# ─── Email ───────────────────────────────────────────────────────────────────
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=noreply@refuconnect.org
EMAIL_HOST_PASSWORD=your-smtp-password-here
DEFAULT_FROM_EMAIL=RefuConnect <noreply@refuconnect.org>

# ─── CORS ────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ─── FastText Model ──────────────────────────────────────────────────────────
FASTTEXT_MODEL_PATH=/app/models/lid.176.bin

# ─── Sentry (optional) ───────────────────────────────────────────────────────
SENTRY_DSN=
